# ── Facebook credentials ─────────────────────────────────────────────
# Your Facebook Page numeric ID (e.g. 123456789012345)
FACEBOOK_PAGE_ID=

# Long-lived Page Access Token from Meta for Developers
# https://developers.facebook.com/tools/explorer/
FACEBOOK_PAGE_ACCESS_TOKEN=

# ── OpenAI (AI content generation) ───────────────────────────────────
# API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Model to use for generation (gpt-4o-mini is cheap and great for Romanian)
OPENAI_MODEL=gpt-4o-mini

# ── Auto-refill settings ──────────────────────────────────────────────
# Generate new content automatically when fewer than N unposted remain
LOW_CONTENT_THRESHOLD=3

# How many curiosities to generate in each auto-refill batch
GENERATE_BATCH_SIZE=5

# ── Unsplash (optional – used for auto-downloading backgrounds) ───────
# Free API key from https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# ── Scheduler settings ────────────────────────────────────────────────
# Max random delay in seconds added before posting (default: 3600 = 1h)
MAX_RANDOM_DELAY_SECONDS=3600
